# ---------------------------------------------------------------------------
# Network (default: Shelbynet)
# Docs: https://docs.shelby.xyz/protocol/architecture/networks
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SHELBY_NETWORK=SHELBYNET

# Public URL used in share links (set in production, e.g. Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Production / wallet mode (default when NEXT_PUBLIC_DEMO_MODE is not "true")
# - Users connect an Aptos wallet; they sign blob registration txs and pay gas.
# - Shelby API key is used by the browser for Shelby RPC (putBlob / download).
#   Create a key in Geomi (client key for web): https://geomi.dev — see:
#   https://docs.shelby.xyz/sdks/typescript/acquire-api-keys
#   Put the value in .env.local locally and in Vercel → Environment Variables
#   (never commit the real key to Git).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SHELBY_API_KEY=

# Optional: Aptos full-node API key for the wallet adapter / extra SDK calls only.
# Do NOT use the Shelby Geomi key here — it can route the Aptos client to Devnet and break uploads.
# NEXT_PUBLIC_APTOS_API_KEY=

# ---------------------------------------------------------------------------
# Demo mode — no wallet, no Shelby upload; files only in server RAM
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_DEMO_MODE=true

# ---------------------------------------------------------------------------
# Optional: Aptos testnet instead of Shelbynet
# NEXT_PUBLIC_SHELBY_NETWORK=TESTNET
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Legacy: server-side Shelby (only if you use server download/upload helpers)
# Not required for the default wallet + NEXT_PUBLIC_SHELBY_API_KEY flow.
# SHELBY_API_KEY=
# SHELBY_ACCOUNT_PRIVATE_KEY=
# ---------------------------------------------------------------------------
